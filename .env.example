# ═══════════════════════════════════════════════════════════════════════════════
#
#   VOIDANIME - Environment Configuration
#   =====================================
#   Copy this file to .env.local and fill in your values.
#   NEVER commit .env.local to version control!
#
#   Environment Variables Reference:
#   - NEXT_PUBLIC_* = Exposed to client-side (browser)
#   - Without NEXT_PUBLIC_ = Server-side only (not exposed to client)
#
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE (Database & Authentication)
# ─────────────────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─────────────────────────────────────────────────────────────────────────────
# ANIME STREAMING API (Kenjitsu-based backend)
# ─────────────────────────────────────────────────────────────────────────────
# Your custom API that scrapes/fetches anime from various providers
# Can be self-hosted or use the hosted version

NEXT_PUBLIC_ANIME_API_BASE_URL=https://api.voidanime.online/api

# ─────────────────────────────────────────────────────────────────────────────
# VIDEO PROXY SERVERS (CORS bypass for streaming)
# ─────────────────────────────────────────────────────────────────────────────
# These proxies bypass CORS restrictions when streaming video content.
# The primary proxy should be your own server for reliability.
# The fallback proxy is a public/shared proxy as backup.
#
# IMPORTANT: These URLs must end with ?url= for proper query string handling

NEXT_PUBLIC_HLS_PROXY_PRIMARY=https://stream.voidanime.online/proxy?url=
NEXT_PUBLIC_HLS_PROXY_FALLBACK=https://proxy-xi-five.vercel.app/proxy?url=

# ─────────────────────────────────────────────────────────────────────────────
# SITE CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
# Basic site settings

NEXT_PUBLIC_APP_URL=https://voidanime.online
NEXT_PUBLIC_SITE_NAME=VoidAnime
NEXT_PUBLIC_SITE_TAGLINE=Watch Anime Online in HD

# ─────────────────────────────────────────────────────────────────────────────
# SOCIAL MEDIA LINKS
# ─────────────────────────────────────────────────────────────────────────────
# Fill in your social media profile URLs. Leave empty to hide.

NEXT_PUBLIC_SOCIAL_DISCORD=
NEXT_PUBLIC_SOCIAL_TELEGRAM=
NEXT_PUBLIC_SOCIAL_REDDIT=
NEXT_PUBLIC_SOCIAL_TWITTER=
NEXT_PUBLIC_SOCIAL_INSTAGRAM=
NEXT_PUBLIC_SOCIAL_YOUTUBE=

# ─────────────────────────────────────────────────────────────────────────────
# ANALYTICS (Optional)
# ─────────────────────────────────────────────────────────────────────────────

# Google Analytics
# NEXT_PUBLIC_GA_TRACKING_ID=

# Google Search Console Verification
# GOOGLE_VERIFICATION_CODE=

# ─────────────────────────────────────────────────────────────────────────────
# ADVERTISING (Optional)
# ─────────────────────────────────────────────────────────────────────────────

# Ad Networks
# NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=
# NEXT_PUBLIC_GOOGLE_AD_CLIENT=

# ─────────────────────────────────────────────────────────────────────────────
# EXTERNAL SERVICES (Optional)
# ─────────────────────────────────────────────────────────────────────────────

# Discord Integration
# NEXT_PUBLIC_DISCORD_SERVER_ID=
# DISCORD_BOT_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# RATE LIMITING & SECURITY
# ─────────────────────────────────────────────────────────────────────────────

# Rate limiting for API endpoints (in requests per minute)
# API_RATE_LIMIT=60

# Secret for NextAuth.js (if using)
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=https://voidanime.online

# ─────────────────────────────────────────────────────────────────────────────
# DEVELOPMENT SETTINGS
# ─────────────────────────────────────────────────────────────────────────────

# Set to 'development' for local development
# NODE_ENV=production
